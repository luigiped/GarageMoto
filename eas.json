{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.20.2"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "node": "20.20.2",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "node": "20.20.2",
      "android": {
        "buildType": "apk"
      }
    }
  }
}
